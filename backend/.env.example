# ===========================================
# BEROE AI PROCUREMENT PLATFORM - BACKEND
# ===========================================

# Application
APP_NAME="Beroe AI Procurement Platform"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/beroe_procurement
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/beroe_procurement

# Redis (for sessions & caching)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI API (for complex LLM tasks)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local LLM (for simple tasks - optional)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=mistral
LOCAL_LLM_BASE_URL=http://localhost:11434

# Hybrid LLM Settings
LLM_PROVIDER=hybrid
# Options: openai, local, hybrid

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls,.pdf,.docx

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3004"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
