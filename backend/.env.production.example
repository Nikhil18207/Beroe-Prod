# ===========================================
# BEROE BACKEND - RAILWAY PRODUCTION CONFIG
# ===========================================
# Copy these to Railway Environment Variables

# ============ APPLICATION ============
APP_NAME="Beroe AI Procurement Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ============ DATABASE ============
# Your Supabase PostgreSQL URL
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_SYNC_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ============ JWT (IMPORTANT: Generate new secret!) ============
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=GENERATE_A_SECURE_64_CHARACTER_HEX_STRING_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ LLM PROVIDERS ============
# Primary: Groq (fast, free tier)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback: OpenAI (for PP8 supplier intelligence)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SUPPLIER_INTEL_MODEL=gpt-4o-mini

# Web Search for Supplier Intelligence
SERPER_API_KEY=your_serper_api_key_here

# ============ CORS ============
# IMPORTANT: Add your Vercel frontend URL here
CORS_ORIGINS=["https://your-app.vercel.app","https://your-app-git-main.vercel.app","http://localhost:3000"]
FRONTEND_URL=https://your-app.vercel.app

# ============ FILE UPLOAD ============
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ SUPER ADMIN ============
# Change this secret in production!
SUPER_ADMIN_SECRET=your-secure-super-admin-secret-here
