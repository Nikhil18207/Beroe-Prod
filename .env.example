# ===========================================
# BEROE AI PROCUREMENT PLATFORM
# Environment Configuration
# ===========================================
# Copy this file to .env and update the values

# ============ APPLICATION ============
APP_NAME="Beroe AI Procurement Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ============ SERVER ============
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============ DATABASE ============
# PostgreSQL connection URL (Supabase or local)
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/beroe_procurement
DATABASE_SYNC_URL=postgresql://postgres:your_password@localhost:5432/beroe_procurement

# ============ SUPABASE (Optional) ============
# If using Supabase for auth/storage/sync
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend Supabase (for client-side sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_SYNC=false  # Set to 'true' in production to enable sync

# ============ REDIS (Optional) ============
# For sessions & caching
REDIS_URL=redis://localhost:6379/0

# ============ JWT AUTHENTICATION ============
# IMPORTANT: Generate a secure random key for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ LLM CONFIGURATION ============
# LLM Provider Selection
# Options: openai, groq, local, hybrid
# - groq: Use Groq (RECOMMENDED - ultra-fast, free tier, with OpenAI fallback)
# - openai: Use OpenAI API only (paid, high quality)
# - local: Use local Ollama/Qwen (development only)
# - hybrid: Try OpenAI first, fallback to Groq/local
LLM_PROVIDER=groq

# Groq (PRIMARY - ultra-fast inference, free tier)
# Get your API key from: https://console.groq.com
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API (FALLBACK - used when Groq fails or rate limited)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Supplier Intelligence (PP8) - Uses OpenAI ONLY (not Groq)
# This is the "super intelligence" for complex supplier risk analysis
SUPPLIER_INTEL_MODEL=gpt-4o-mini

# Serper API (for real-time web search in supplier intelligence)
# Get your API key from: https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Local LLM (Ollama + Qwen 2.5) - FOR LOCAL DEVELOPMENT ONLY
# Install Ollama: https://ollama.ai
# Then run: ollama pull qwen2.5:7b
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_BASE_URL=http://localhost:11434

# ============ FILE UPLOAD ============
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls,.pdf,.docx,.doc,.txt,.md

# ============ CORS ============
# Frontend URLs allowed to access the API
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3004"]

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ FRONTEND (Next.js) ============
# Backend API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Beroe Procurement Platform
NEXT_PUBLIC_APP_VERSION=1.0.0
