# ===========================================
# BEROE AI PROCUREMENT PLATFORM
# Environment Configuration
# ===========================================
# Copy this file to .env and update the values

# ============ APPLICATION ============
APP_NAME="Beroe AI Procurement Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ============ SERVER ============
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============ DATABASE ============
# PostgreSQL connection URL
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/beroe_procurement

# ============ REDIS (Optional) ============
# For sessions & caching
REDIS_URL=redis://localhost:6379/0

# ============ JWT AUTHENTICATION ============
# IMPORTANT: Generate a secure random key for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ LLM CONFIGURATION ============
# OpenAI API (for complex LLM tasks)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local LLM (Ollama + Qwen 2.5)
# Install Ollama: https://ollama.ai
# Then run: ollama pull qwen2.5:7b
LOCAL_LLM_ENABLED=true
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_BASE_URL=http://localhost:11434

# LLM Provider Selection
# Options: openai, local, hybrid
# - openai: Use OpenAI API for all tasks
# - local: Use local Ollama/Qwen for all tasks
# - hybrid: Use local for simple tasks, OpenAI for complex
LLM_PROVIDER=local

# ============ FILE UPLOAD ============
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls,.pdf,.docx,.doc,.txt,.md

# ============ CORS ============
# Frontend URLs allowed to access the API
CORS_ORIGINS=["http://localhost:3000","http://localhost:3004"]

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ FRONTEND (Next.js) ============
# Backend API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Beroe Procurement Platform
NEXT_PUBLIC_APP_VERSION=1.0.0
