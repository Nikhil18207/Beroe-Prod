# ===========================================
# BEROE PROCUREMENT PLATFORM - GITIGNORE
# ===========================================

# ============ DEPENDENCIES ============
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============ BUILD OUTPUTS ============
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ============ ENVIRONMENT VARIABLES ============
# Ignore all .env files (contain secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
backend/.env
frontend/.env.local

# Keep .env.example for documentation
!.env.example
!**/.env.example

# ============ DEBUG & LOGS ============
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ============ IDE & EDITORS ============
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ============ OS FILES ============
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============ TESTING ============
coverage/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover

# ============ SECURITY & SECRETS ============
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# ============ PYTHON (BACKEND) ============
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
.venv/
ENV/
prod/
*.egg-info/
.eggs/
*.egg
.installed.cfg
develop-eggs/
downloads/
eggs/
# Python lib folders (not frontend/src/lib)
backend/lib/
lib64/
parts/
sdist/
var/
wheels/
.mypy_cache/
.dmypy.json
dmypy.json

# ============ UPLOADS & TEMP FILES ============
uploads/
temp/
tmp/
*.tmp

# ============ DATABASE FILES ============
*.db
*.sqlite
*.sqlite3

# ============ ML MODELS (Large files) ============
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.safetensors
!models/.gitkeep

# ============ MISC ============
.vercel
.turbo
*.local

# ============ CLAUDE CODE ============
.claude/

